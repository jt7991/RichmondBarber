---
import Navigation from "../components/Navigation.astro";
import logoImage from "../assets/sms_preview.webp";
import heroImage from "../assets/hero.webp";

const defaultTitle = "Richmond Barbershop | Barber in Richmond, VA";
const defaultDescription =
  "Richmond Barbershop in Carytown offers precision haircuts, beard trims, and straight razor shaves. Book your appointment today.";

const {
  title = defaultTitle,
  description = defaultDescription,
  canonical = Astro.url.href,
} = Astro.props;

const barbershopSchema = {
  "@context": "https://schema.org",
  "@type": "Barbershop",
  name: "Richmond Barbershop",
  description,
  url: "https://richmondbarbershop.com",
  image: `https://richmondbarbershop.com${logoImage.src}`,
  telephone: "+18042030221",
  address: {
    "@type": "PostalAddress",
    streetAddress: "2820 W Cary St STE C",
    addressLocality: "Richmond",
    addressRegion: "VA",
    postalCode: "23221",
    addressCountry: "US",
  },
  hasMap: "https://maps.app.goo.gl/gv7wy3RtPVX4iEvw8",
  sameAs: [
    "https://share.google/wbJjqNOCH4Rwny71W",
    "https://instagram.com/rvabarbershop",
    "https://www.facebook.com/profile.php?id=61584927026935",
  ],
  areaServed: [
    "Richmond, VA",
    "Carytown",
    "The Fan",
    "Museum District",
    "Scott's Addition",
    "Church Hill",
    "West End",
    "Henrico",
    "Midlothian",
  ],
  serviceType: [
    "Men's Haircut",
    "Scissor Cut",
    "Beard Trim",
    "Straight Razor Shave",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script
      defer
      src="https://analytics.jakey.fyi/script.js"
      data-website-id="b49bd076-e074-4f7b-8a66-c9aefdb94c0c"></script>
    <link rel="icon" href="/favicon.ico?p=1" type="image/x-icon" />

    <link rel="preload" href={logoImage.src} as="image" />
    <link rel="dns-prefetch" href="//images.unsplash.com" />
    <link rel="dns-prefetch" href="//www.instagram.com" />
    <link rel="dns-prefetch" href="//www.google.com" />
    <link
      rel="preload"
      as="image"
      href={heroImage.src}
      crossorigin="anonymous"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta
      property="og:image"
      content={`https://richmondbarbershop.com${logoImage.src}`}
    />
    <meta
      property="og:image:alt"
      content="Richmond barbershop interior and services"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={`https://richmondbarbershop.com${logoImage.src}`}
    />
    <link rel="canonical" href={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(barbershopSchema)} />
    <slot name="head" />
    <style>
      body {
        font-family: "Oswald", sans-serif;
      }
    </style>
  </head>

  <body class="font-sans">
    <Navigation />
    <slot />
  </body>
</html>
