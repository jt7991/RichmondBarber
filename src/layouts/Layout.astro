---
import Navigation from "../components/Navigation.astro";
import logoImage from "../assets/sms_preview.webp";
import heroImage from "../assets/hero.webp";
import {
  ADDRESS,
  BOOKING_URL,
  BUSINESS_HOURS_NOTE,
  BUSINESS_NAME,
  FACEBOOK_URL,
  GOOGLE_PROFILE_URL,
  INSTAGRAM_URL,
  MAPS_URL,
  PHONE_DISPLAY,
  PHONE_E164,
  SERVICE_AREAS,
  SERVICES,
  WEBSITE_URL,
} from "../data/business";

const defaultTitle = `${BUSINESS_NAME} | Barber in Richmond, VA`;
const defaultDescription =
  "Richmond Barbershop in Carytown offers precision haircuts, beard trims, and straight razor shaves. Book your appointment today.";

const {
  title = defaultTitle,
  description = defaultDescription,
  canonical = Astro.url.href,
} = Astro.props;

const barbershopSchema = {
  "@context": "https://schema.org",
  "@type": "Barbershop",
  name: BUSINESS_NAME,
  description,
  url: WEBSITE_URL,
  image: `${WEBSITE_URL}${logoImage.src}`,
  telephone: PHONE_E164,
  address: {
    "@type": "PostalAddress",
    ...ADDRESS,
  },
  hasMap: MAPS_URL,
  sameAs: [GOOGLE_PROFILE_URL, INSTAGRAM_URL, FACEBOOK_URL],
  areaServed: SERVICE_AREAS,
  serviceType: SERVICES.map((service) => service.name),
};

const copyrightYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script
      defer
      src="https://analytics.jakey.fyi/script.js"
      data-website-id="b49bd076-e074-4f7b-8a66-c9aefdb94c0c"></script>
    <link rel="icon" href="/favicon.ico?p=1" type="image/x-icon" />

    <link rel="preload" href={logoImage.src} as="image" />
    <link rel="dns-prefetch" href="//images.unsplash.com" />
    <link rel="dns-prefetch" href="//www.instagram.com" />
    <link rel="dns-prefetch" href="//www.google.com" />
    <link
      rel="preload"
      as="image"
      href={heroImage.src}
      crossorigin="anonymous"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta
      property="og:image"
      content={`${WEBSITE_URL}${logoImage.src}`}
    />
    <meta
      property="og:image:alt"
      content="Richmond barbershop interior and services"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={`${WEBSITE_URL}${logoImage.src}`}
    />
    <link rel="canonical" href={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(barbershopSchema)} />
    <slot name="head" />
    <style>
      body {
        font-family: "Oswald", sans-serif;
      }
    </style>
  </head>

  <body class="font-sans">
    <Navigation />
    <slot />
    <footer
      class="bg-gray-100 dark:bg-zinc-950 text-black dark:text-white border-t border-gray-300 dark:border-zinc-800 py-8 px-4"
    >
      <div class="max-w-7xl mx-auto flex flex-col gap-2 text-center text-sm md:text-base">
        <p class="font-semibold">{BUSINESS_NAME}</p>
        <p>
          <a class="underline" href={`tel:${PHONE_E164}`}>{PHONE_DISPLAY}</a>
          ·
          <a class="underline" href={MAPS_URL} target="_blank" rel="noopener noreferrer"
            >{ADDRESS.streetAddress}, {ADDRESS.addressLocality}, {ADDRESS.addressRegion} {ADDRESS.postalCode}</a
          >
        </p>
        <p>
          {BUSINESS_HOURS_NOTE}
          <a class="underline" href={MAPS_URL} target="_blank" rel="noopener noreferrer"
            >View live hours</a
          >
        </p>
        <p class="text-xs opacity-70">&copy; {copyrightYear} {BUSINESS_NAME}. All rights reserved.</p>
      </div>
    </footer>
    <script is:inline define:vars={{ BOOKING_URL }}>
      (() => {
        document.querySelectorAll('a[href]').forEach((link) => {
          const href = link.getAttribute('href') || '';
          if (link.getAttribute('data-umami-event')) {
            return;
          }

          if (href.startsWith('tel:')) {
            link.setAttribute('data-umami-event', 'phone-click');
            return;
          }

          if (href.startsWith(BOOKING_URL)) {
            link.setAttribute('data-umami-event', 'booking-click');
            return;
          }

          if (href.includes('maps.app.goo.gl') || href.includes('google.com/maps')) {
            link.setAttribute('data-umami-event', 'directions-click');
            return;
          }

          if (href.startsWith('http') && link.host !== window.location.host) {
            link.setAttribute('data-umami-event', 'outbound-link-click');
            link.setAttribute('data-umami-event-url', link.href);
          }
        });
      })();
    </script>
  </body>
</html>
